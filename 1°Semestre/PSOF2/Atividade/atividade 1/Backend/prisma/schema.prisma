generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  }

enum Categoria {
  Anel
  Brinco
  Colar
  Pulseira
}

model Joia {
  id        Int       @id @default(autoincrement())
  nome      String
  imagem    String
  preco     Float
  categoria Categoria
  pedras    String
  colecao   String
}